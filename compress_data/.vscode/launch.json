{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "运行光谱压缩上位机",
            "type": "debugpy",
            "request": "launch",
            "module": "spectrum_compressor.main",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "无界面 UI 冒烟检查",
            "type": "debugpy",
            "request": "launch",
            "module": "unittest",
            "args": [
                "tests.test_ui",
                "-v"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "QT_QPA_PLATFORM": "offscreen"
            }
        }
    ]
}
