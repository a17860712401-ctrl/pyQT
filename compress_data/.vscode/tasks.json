{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "创建虚拟环境",
            "type": "process",
            "command": "python",
            "args": [
                "-m",
                "venv",
                ".venv"
            ],
            "problemMatcher": []
        },
        {
            "label": "安装项目依赖",
            "type": "process",
            "command": "python",
            "args": [
                "-m",
                "pip",
                "install",
                "-e",
                ".[dev]"
            ],
            "problemMatcher": []
        },
        {
            "label": "运行全部测试",
            "type": "process",
            "command": "python",
            "args": [
                "-m",
                "unittest",
                "discover",
                "-s",
                "tests",
                "-v"
            ],
            "options": {
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/src",
                    "QT_QPA_PLATFORM": "offscreen"
                }
            },
            "group": "test",
            "problemMatcher": []
        }
    ]
}
